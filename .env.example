# ── Bot credentials (required for the bot process) ────────────────
ANTHROPIC_API_KEY=
REPSLY_USERNAME=
REPSLY_PASSWORD=
REPSLY_BASE_URL=
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_RECIPIENTS=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
IMGBB_API_KEY=

# ── WhatsApp group IDs (one per team, from config/teams.js) ───────
SPAR_GROUP_ID=

# ── Manager WhatsApp numbers ──────────────────────────────────────
VANESSA_WA=
TALITHA_WA=

# ── Testing ───────────────────────────────────────────────────────
TEST_WA_NUMBER=   # set this to route all WA messages to one number

# ── Dashboard (required for src/api.js) ──────────────────────────
DASHBOARD_PORT=3001

# Host to bind. 0.0.0.0 = accessible to everyone on the network (default).
# Set to 127.0.0.1 to restrict to localhost only.
DASHBOARD_HOST=0.0.0.0

COMPANY_NAME=PFM
COMPANY_LOGO_URL=       # optional: URL to your company logo image

# Password to protect the dashboard when accessed over the network.
# Directors enter this once — it is stored in their browser localStorage.
# Leave blank for no password (fine for a trusted internal LAN).
DASHBOARD_PASSWORD=

# ── Public sharing via ngrok (optional) ──────────────────────────
# Allows directors to share a public HTTPS link to the dashboard.
# 1. Sign up free at https://ngrok.com
# 2. Copy your authtoken from the ngrok dashboard
# 3. Paste it below, then run: pm2 reload ecosystem.config.js
# The public URL appears in logs and as a "Share" button in the dashboard.
NGROK_AUTHTOKEN=
# Optional: fixed custom domain (requires ngrok paid plan)
# NGROK_DOMAIN=dashboard.yourcompany.com
