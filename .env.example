REPSLY_USERNAME=
REPSLY_PASSWORD=
REPSLY_BASE_URL=
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_RECIPIENTS=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
IMGBB_API_KEY=

# ── WhatsApp group IDs (one per team, from config/teams.js) ───────
